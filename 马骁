<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <title>朔夜核心终端 3.2</title>
    <style>
        :root { color-scheme: dark; } /* 消除白色物质的关键 */
        body { background: #000; color: #00ff00; font-family: monospace; padding: 20px; }
        .panel { border: 1px solid #005500; padding: 20px; margin-bottom: 20px; box-shadow: 0 0 10px rgba(0,255,0,0.1); }
        .panel-title { color: #ffff00; font-weight: bold; margin-bottom: 15px; border-left: 4px solid #00ff00; padding-left: 10px; }
        input, select, textarea { background: #050505; color: #00ff00; border: 1px solid #004400; padding: 15px; width: 100%; box-sizing: border-box; margin-bottom: 10px; font-size: 16px; }
        button { background: #00ff00; color: #000; border: none; padding: 15px; font-weight: bold; width: 100%; cursor: pointer; margin-bottom: 10px; }
        .danger-btn { background: #aa0000; color: #fff; }
        .bug-item { background: #0a0a0a; border: 1px solid #003300; padding: 10px; margin: 10px 0; position: relative; }
        .del-btn { position: absolute; right: 5px; top: 5px; background: #500; color: #f00; border: 1px solid #f00; width: auto; padding: 2px 8px; font-size: 12px; }
        .hidden { display: none; }
    </style>
</head>
<body>
    <h1>[ SHUOYE TERMINAL 3.2 ]</h1>

    <!-- 模块 A：双轨倒计时 -->
    <div class="panel">
        <div class="panel-title">>_ 倒计时系统</div>
        <input type="text" id="tMin" placeholder="总时长(分)">
        <input type="text" id="taskCode" placeholder="任务代号">
        <button onclick="startTimer()">[ ⚡️ 启动 ]</button>
        <div id="disp" style="font-size: 2em; text-align: center; color: #00aaff;">00:00:00</div>
    </div>

    <!-- 模块 B：漏洞歼灭 (错题库) -->
    <div class="panel" style="border-color: #500;">
        <div class="panel-title" style="color:#ff3333;">>_ 漏洞记录 (错题/图文绑定)</div>
        <textarea id="bCon" placeholder="分析漏洞内容..."></textarea>
        <input type="file" id="bFile" accept="image/*">
        <button class="danger-btn" onclick="saveBug()">[ 🔒 存入终端并同步云端 ]</button>
        <div id="bList"></div>
    </div>

    <!-- 模块 C：资料归档 (资料库) -->
    <div class="panel">
        <div class="panel-title">>_ 战备资料 (纯文件资料库)</div>
        <input type="text" id="dName" placeholder="资料名称">
        <input type="file" id="dFile">
        <button onclick="upDoc()">[ 🚀 归档 ]</button>
    </div>

    <script>
        // 🚨 填入你的信息 🚨
        const CONFIG = {
            token: "ghp_" + "NgjVDt0wwvqKpYvpVbcwAerV8LuRgs2EHAov", // 
            user: "zhejiangsmith0803-alt",
            repo: "L"
        };

        // --- 逻辑部分 ---
        function renderBugs() {
            let arr = JSON.parse(localStorage.getItem('bugs')||'[]');
            document.getElementById('bList').innerHTML = arr.map((x,i) => 
                `<div class="bug-item"><button class="del-btn" onclick="delB(${i})">X</button>
                <div style="color:#0f0">${x.c}</div><div style="font-size:10px; color:#888">${x.t}</div></div>`
            ).join('');
        }
        window.delB = (i) => { if(confirm("删除吗？")){ let a=JSON.parse(localStorage.getItem('bugs')); a.splice(i,1); localStorage.setItem('bugs',JSON.stringify(a)); renderBugs(); } };

        async function saveBug() {
            const con = document.getElementById('bCon').value;
            const file = document.getElementById('bFile').files[0];
            let arr = JSON.parse(localStorage.getItem('bugs')||'[]');
            arr.unshift({c:con, t:new Date().toLocaleString()});
            localStorage.setItem('bugs', JSON.stringify(arr));
            renderBugs();
            if(file) await push(file, `错题库/${new Date().toISOString().split('T')[0]}-错题`);
            alert("本地及云端已同步！");
        }

        async function upDoc() {
            const name = document.getElementById('dName').value;
            const file = document.getElementById('dFile').files[0];
            if(file) await push(file, `资料库/${name}`);
            alert("资料归档成功！");
        }

        async function push(file, path) {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = async () => {
                const base = reader.result.split(',')[1];
                await fetch(`https://api.github.com/repos/${CONFIG.user}/${CONFIG.repo}/contents/${path}`, {
                    method: 'PUT',
                    headers: { 'Authorization': `token ${CONFIG.token}` },
                    body: JSON.stringify({ message: 'upload', content: base })
                });
            };
        }
        renderBugs();
    </script>
</body>
</html>
